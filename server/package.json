    "mongoose": "^8.21.2",
    "zod": "^4.3.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.6",
    "esbuild": "^0.27.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  }
